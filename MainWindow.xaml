<Window x:Class="CodeSummarizer.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Code Summarizer" Width="1280" Height="820" MinWidth="920" MinHeight="640"
        WindowStartupLocation="CenterScreen" Background="{StaticResource CanvasBrush}"
        FontFamily="Segoe UI" Foreground="{StaticResource TextBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E2E9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#E9EBF2" />
            <Setter Property="Foreground" Value="#3C4357" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#DDE0E9" /></Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="28,20" Background="#667EEA">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Code Summarizer" FontSize="26" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="Local-first code analysis · Privacy-first · No cloud calls"
                               Margin="0,4,0,0" FontSize="13" Foreground="#EEF0FF" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="WINDOWS NATIVE" Foreground="White" FontWeight="Bold" FontSize="11"
                               HorizontalAlignment="Right" />
                    <TextBlock Text="Ollama on 127.0.0.1 only" Foreground="#EEF0FF" FontSize="11" Margin="0,3,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="22,18,22,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" MinWidth="400" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.8*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="LANGUAGE" Style="{StaticResource LabelStyle}" />
                        <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="LOCAL MODEL" Style="{StaticResource LabelStyle}" />
                        <ComboBox ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}"
                                  ToolTip="Models installed in Ollama" />
                    </StackPanel>
                    <Button Grid.Column="4" Content="↻" Command="{Binding RefreshModelsCommand}" FontSize="18"
                            Padding="12,6" VerticalAlignment="Bottom" ToolTip="Refresh Ollama models" />
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                    <CheckBox IsChecked="{Binding RedactSecrets}" IsEnabled="{Binding CanToggleRedaction}"
                              Content="Mask potential secrets before sending code to the local model" Margin="0,0,0,7" />
                    <CheckBox IsChecked="{Binding SensitiveMode}" Content="Sensitive Mode (enforce redaction and hide raw output)" />
                    <Border Background="#E8EAFB" CornerRadius="5" Padding="9" Margin="0,8,0,0"
                            Visibility="{Binding SensitiveMode, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding SensitiveModeMessage}" Foreground="#3949AB" TextWrapping="Wrap" FontSize="12" />
                    </Border>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="CODE TO ANALYZE" Style="{StaticResource LabelStyle}" />
                    <TextBox Grid.Row="1" Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True"
                             AcceptsTab="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Cascadia Mono, Consolas" FontSize="13" TextWrapping="NoWrap"
                             SpellCheck.IsEnabled="False" MinHeight="230" />
                </Grid>

                <WrapPanel Grid.Row="3" Margin="0,12,0,0">
                    <Button Content="Summarize" Command="{Binding AnalyzeCommand}" CommandParameter="summarize" Margin="0,0,8,8" />
                    <Button Content="Explain for Junior" Command="{Binding AnalyzeCommand}" CommandParameter="junior" Margin="0,0,8,8" />
                    <Button Content="Risk Scan" Command="{Binding AnalyzeCommand}" CommandParameter="risk" Margin="0,0,8,8" />
                    <Button Content="Validate" Command="{Binding AnalyzeCommand}" CommandParameter="validate" Margin="0,0,8,8" />
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8" />
                    <Button Content="Clear" Command="{Binding ClearCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,0,8" />
                </WrapPanel>
            </Grid>

            <Border Grid.Column="2" Background="White" BorderBrush="#E0E2E9" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="18,14,18,10">
                        <TextBlock Text="Analysis" FontSize="18" FontWeight="SemiBold" />
                        <Button Content="Copy report" HorizontalAlignment="Right" Padding="10,6"
                                Command="{Binding CopyAllCommand}" />
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,0,18,18">
                        <StackPanel>
                            <Border Style="{StaticResource CardStyle}" Background="#FFF1F1" BorderBrush="#F4B8B8"
                                    Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <TextBlock Text="Something needs attention" FontWeight="SemiBold" Foreground="#9B1C1C" />
                                    <TextBlock Text="{Binding ErrorText}" TextWrapping="Wrap" Margin="0,5,0,0" Foreground="#7A1C1C" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Background="#FFF8E1" BorderBrush="#F0CF76"
                                    Visibility="{Binding HasWarning, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <TextBlock Text="Potential secrets detected" FontWeight="SemiBold" Foreground="#795B00" />
                                    <TextBlock Text="{Binding WarningText}" TextWrapping="Wrap" Margin="0,5,0,0" Foreground="#6D5400" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Visibility="{Binding HasValidation, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding ValidationText}" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{Binding ValidationColor}" />
                            </Border>

                            <ItemsControl ItemsSource="{Binding Sections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,9">
                                                    <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" />
                                                    <Button Content="Copy" HorizontalAlignment="Right" Padding="9,4" FontSize="11"
                                                            Command="{Binding DataContext.CopySectionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding Content}" />
                                                </Grid>
                                                <Separator Background="#E6E8EF" Margin="0,0,0,10" />
                                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" LineHeight="21" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Style="{StaticResource CardStyle}" Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Confidence" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ConfidenceText}" HorizontalAlignment="Right" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" />
                                    </Grid>
                                    <ProgressBar Value="{Binding Confidence, Mode=OneWay}" Maximum="1" Height="12" Foreground="{StaticResource PrimaryBrush}" />
                                </StackPanel>
                            </Border>

                            <Expander Header="Raw model output" Visibility="{Binding ShowRawOutput, Converter={StaticResource BoolToVisibility}}"
                                      Margin="0,4,0,8">
                                <TextBox Text="{Binding RawOutput, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" Margin="0,8,0,0"
                                         FontFamily="Cascadia Mono, Consolas" FontSize="11" MaxHeight="260"
                                         VerticalScrollBarVisibility="Auto" />
                            </Expander>

                            <StackPanel Margin="18,40" Visibility="{Binding HasNoResult, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Paste code and choose an analysis mode." HorizontalAlignment="Center"
                                           Foreground="{StaticResource MutedTextBrush}" FontSize="14" />
                                <TextBlock Text="Your code is sent only to Ollama on this computer." HorizontalAlignment="Center"
                                           Foreground="#9AA0B2" FontSize="12" Margin="0,6,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#ECEEF4" Padding="22,8">
            <Grid>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                <TextBlock Text="{Binding BusyText}" HorizontalAlignment="Right" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
            </Grid>
        </Border>
    </Grid>
</Window>
